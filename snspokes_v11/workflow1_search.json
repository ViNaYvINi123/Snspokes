{
  "name": "SNSpokes - Search Pipeline v2",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sn-search-spokes",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Search Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Validate and normalize query\nconst body = $input.first().json;\nconst query = (body.query || body.search || '').trim().toLowerCase();\n\nif (!query || query.length < 2) {\n  return [{ json: { valid: false, error: 'Query too short', query } }];\n}\nif (query.length > 200) {\n  return [{ json: { valid: false, error: 'Query too long', query } }];\n}\n\nreturn [{ json: { valid: true, query, original: body.query } }];"
      },
      "id": "validate",
      "name": "Validate Query",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.valid }}", "value2": true }]
        }
      },
      "id": "check-valid",
      "name": "Is Valid?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT slug, name, description, icon, category, plugin_id, credential_type, tags FROM sn_spokes WHERE LOWER(name) LIKE '%' || LOWER($1) || '%' OR LOWER(description) LIKE '%' || LOWER($1) || '%' OR LOWER(category) LIKE '%' || LOWER($1) || '%' ORDER BY view_count DESC LIMIT 8",
        "additionalFields": { "queryParams": "={{ [$json.query] }}" }
      },
      "id": "db-search",
      "name": "Search Database",
      "type": "n8n-nodes-base.postgres",
      "credentials": { "postgres": { "id": "1", "name": "Postgres" } },
      "position": [900, 200]
    },
    {
      "parameters": {
        "jsCode": "const dbResults = $input.all();\nconst query = $('Validate Query').first().json.query;\nconst results = dbResults.map(r => r.json);\n\nreturn [{ json: { success: true, results, count: results.length, source: 'database', query } }];"
      },
      "id": "format-results",
      "name": "Format Results",
      "type": "n8n-nodes-base.code",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "const query = $('Validate Query').first().json.query;\nreturn [{ json: { success: false, results: [], error: $json.error || 'Invalid query', query } }];"
      },
      "id": "invalid-response",
      "name": "Invalid Response",
      "type": "n8n-nodes-base.code",
      "position": [900, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseHeaders": { "entries": [{ "name": "Content-Type", "value": "application/json" }, { "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "respond",
      "name": "Send Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1340, 300]
    }
  ],
  "connections": {
    "Search Webhook": { "main": [[{ "node": "Validate Query", "type": "main", "index": 0 }]] },
    "Validate Query": { "main": [[{ "node": "Is Valid?", "type": "main", "index": 0 }]] },
    "Is Valid?": {
      "main": [
        [{ "node": "Search Database", "type": "main", "index": 0 }],
        [{ "node": "Invalid Response", "type": "main", "index": 0 }]
      ]
    },
    "Search Database": { "main": [[{ "node": "Format Results", "type": "main", "index": 0 }]] },
    "Format Results": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] },
    "Invalid Response": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
