# ============================================================
# snspokes — Backup & DR Environment Variables
# Copy to: /root/snspokes/.env.backup
# ============================================================

# Remote Storage (Cloudflare R2 recommended — free 10GB)
S3_BUCKET=s3://snspokes-backups
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key
AWS_DEFAULT_REGION=auto

# Backup encryption (KEEP THIS SAFE — you can't restore without it!)
BACKUP_ENCRYPT_KEY=changeme-use-32chars-strong-key!

# Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ADMIN_EMAIL=admin@yourdomain.com
APP_URL=https://yourdomain.com
