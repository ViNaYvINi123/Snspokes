# ══════════════════════════════════════════
# snspokes — Production Environment Config
# Copy to .env.local and fill in your values
# ══════════════════════════════════════════

# ── Database (Docker internal) ──
DB_HOST=snspokes_db
DB_PORT=5432
DB_NAME=snspokes
DB_USER=snspokes_user
DB_PASSWORD=CHANGE_ME_strong_password
DB_POOL_MAX=25

# ── Redis (Docker internal) ──
REDIS_HOST=snspokes_redis
REDIS_PORT=6379

# ── n8n (Docker internal — ALL AI goes through n8n) ──
N8N_URL=http://snspokes_n8n:5678
N8N_TIMEOUT=90000

# ── Auth ──
NEXTAUTH_URL=https://snspokes.com
NEXTAUTH_SECRET=CHANGE_ME_random_32_chars

# ── Google OAuth ──
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: https://snspokes.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenRouter AI (used by n8n workflows) ──
# Get free key at https://openrouter.ai/keys
# This is passed to n8n via docker-compose
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Ollama (local AI — unlimited, free) ──
# Install: curl -fsSL https://ollama.com/install.sh | sh && ollama pull llama3.1:8b
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Admin Panel ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_SECRET=CHANGE_ME_random_admin_secret

# ── Email (optional) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@snspokes.com
SMTP_FROM_NAME=snspokes

# ── Payment (optional) ──
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
