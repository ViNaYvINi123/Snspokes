# ============================================
# snspokes v5 - Environment Variables
# On Hetzner: nano ~/snspokes/app/.env.local
# ============================================

# App
NEXTAUTH_URL=http://77.42.71.149
NEXTAUTH_SECRET=snspokes-nextauth-secret-change-this-2025
NODE_ENV=production

# n8n (used for list spokes)
N8N_URL=http://snspokes_n8n:5678
NEXT_PUBLIC_N8N_URL=http://77.42.71.149:5678

# Database
DB_HOST=snspokes_db
DB_PORT=5432
DB_NAME=snspokes
DB_USER=snspokes_user
DB_PASSWORD=Vinay@123

# Redis (OPTIONAL - system works without it)
# Add Redis to docker-compose then enable:
REDIS_HOST=snspokes_redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AI Config ──
# Primary: Ollama (already on your Hetzner server)
OLLAMA_URL=http://172.19.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: OpenRouter (FREE models available at openrouter.ai)
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Rate Limiting
RATE_LIMIT=30

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=snspokes@admin2025
ADMIN_SECRET=snspokes-admin-jwt-secret-2025

# Razorpay (optional)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-secret

# ── Security ──
# Encryption key for API credentials (exactly 32 chars)
ENCRYPTION_KEY=snspokes-encryption-key-32chars!

# Trusted IPs (comma separated) for admin access
TRUSTED_IPS=

# Cookie settings
COOKIE_DOMAIN=localhost

# ── Email (Your Hetzner SMTP Server) ──
SMTP_HOST=mail.your-hetzner-domain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@your-domain.com
SMTP_PASS=your-email-password
SMTP_FROM_NAME=snspokes
SMTP_FROM_EMAIL=noreply@your-domain.com

# ── Backup ──
BACKUP_DIR=/tmp/snspokes-backups

# Razorpay (Payment)
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Backup & DR
BACKUP_ENCRYPT_KEY=changeme-32chars-key!
S3_BUCKET=s3://snspokes-backups
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com


# === ADDITIONAL SETTINGS ===

# Admin email for backup alerts
ADMIN_EMAIL=admin@snspokes.com

# GitHub OAuth app client ID
GITHUB_CLIENT_ID=your-github-client-id

# GitHub OAuth app secret
GITHUB_CLIENT_SECRET=your-github-client-secret

# Logging level: debug/info/warn/error
LOG_LEVEL=info

# Max DB connections in pool
DB_POOL_MAX=10

# n8n webhook timeout in ms
N8N_TIMEOUT=90000

# Set to true for local dev without DB
MOCK_MODE=false