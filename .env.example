# ══════════════════════════════════════════════
# snspokes .env.local — copy this to .env.local
# ══════════════════════════════════════════════

# ── Database ───────────────────────────────────
DB_HOST=pgbouncer
DB_PORT=5432
DB_NAME=snspokes
DB_USER=snspokes_user
DB_PASSWORD=your_secure_password

# ── Redis ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Auth ──────────────────────────────────────
NEXTAUTH_URL=https://snspokes.com
NEXTAUTH_SECRET=generate_with: openssl rand -base64 32

# ── Admin ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET=same_as_or_diff_from_nextauth_secret
ENCRYPTION_KEY=generate_with: openssl rand -hex 32

# ── AI Providers (ALL FREE — get in 2 minutes) ─
# Gemini: aistudio.google.com → Get API Key (free, no card)
GEMINI_API_KEY=

# Groq: console.groq.com → API Keys → Create (free, fastest)
GROQ_API_KEY=

# Ollama: self-hosted (optional, runs on your server)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ── Google OAuth (optional) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (optional) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@snspokes.com
SMTP_FROM_NAME=snspokes

# ── Payments (optional) ───────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Cron ──────────────────────────────────────
CRON_SECRET=generate_with: openssl rand -hex 16
