# ============================================================
# snspokes — Mock Environment
# Copy to .env.local for local development WITHOUT real DB
# Usage: cp .env.mock .env.local && npm run dev
# ============================================================

# MOCK MODE — set to true to skip DB/Redis/n8n
MOCK_MODE=true

# Auth (required even in mock mode)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=mock-secret-32-chars-minimum-ok!

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=snspokes@admin2025
ADMIN_SECRET=mock-admin-secret-key

# These don't matter in mock mode but are needed for Next.js
DB_HOST=localhost
DB_PORT=5432
DB_NAME=snspokes
DB_USER=snspokes_user
DB_PASSWORD=Vinay@123

REDIS_HOST=localhost
REDIS_PORT=6379

OPENROUTER_API_KEY=mock-key-not-used
N8N_URL=http://localhost:5678

RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=mock_secret
RAZORPAY_WEBHOOK_SECRET=mock_webhook_secret

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=test@test.com
SMTP_PASS=testpass
SMTP_FROM_EMAIL=noreply@snspokes.com
SMTP_FROM_NAME=snspokes

ENCRYPTION_KEY=mock-encryption-key-32chars-ok!!
BACKUP_ENCRYPT_KEY=mock-backup-key-32chars-minimum!

# Mocked AI responses - no real API needed
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b


# Additional settings
ADMIN_EMAIL=admin@snspokes.com
GITHUB_CLIENT_ID=mock-github-id
GITHUB_CLIENT_SECRET=mock-github-secret
LOG_LEVEL=debug
DB_POOL_MAX=5
N8N_TIMEOUT=90000
BACKUP_DIR=/tmp/snspokes-backups