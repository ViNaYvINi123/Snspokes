{
  "name": "SNSpokes - AI Chatbot v2",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sn-chatbot",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Chatbot Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst question = (body.question || '').trim();\n\nif (!question || question.length < 3) {\n  return [{ json: { valid: false, error: 'Question too short' } }];\n}\n\nreturn [{ json: { valid: true, question, history: body.history || [] } }];"
      },
      "id": "validate",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.valid }}", "value2": true }] }
      },
      "id": "check-valid",
      "name": "Is Valid?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "http://172.19.0.1:11434/api/chat",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "llama3.2:3b" },
            { "name": "stream", "value": false },
            {
              "name": "messages",
              "value": "={{ [{role:'system',content:'You are an expert ServiceNow Integration Hub assistant. Only answer ServiceNow-related questions. Be concise and practical.'},{role:'user',content:$json.question}] }}"
            }
          ]
        },
        "options": { "timeout": 90000, "response": { "response": { "neverError": true } } }
      },
      "id": "ollama",
      "name": "Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 200]
    },
    {
      "parameters": {
        "jsCode": "const ollamaRes = $input.first().json;\nconst answer = ollamaRes?.message?.content || ollamaRes?.response || 'Sorry, AI is temporarily unavailable.';\nconst question = $('Validate Input').first().json.question;\n\nreturn [{ json: { success: true, answer, question, model: ollamaRes?.model || 'llama3.2:3b', timestamp: new Date().toISOString() } }];"
      },
      "id": "format",
      "name": "Format Answer",
      "type": "n8n-nodes-base.code",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: false, answer: '⚠️ Invalid request: ' + ($json.error || 'Question required') } }];"
      },
      "id": "error-response",
      "name": "Error Response",
      "type": "n8n-nodes-base.code",
      "position": [900, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseHeaders": { "entries": [{ "name": "Content-Type", "value": "application/json" }, { "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "respond",
      "name": "Send Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1340, 300]
    }
  ],
  "connections": {
    "Chatbot Webhook": { "main": [[{ "node": "Validate Input", "type": "main", "index": 0 }]] },
    "Validate Input": { "main": [[{ "node": "Is Valid?", "type": "main", "index": 0 }]] },
    "Is Valid?": {
      "main": [
        [{ "node": "Call Ollama", "type": "main", "index": 0 }],
        [{ "node": "Error Response", "type": "main", "index": 0 }]
      ]
    },
    "Call Ollama": { "main": [[{ "node": "Format Answer", "type": "main", "index": 0 }]] },
    "Format Answer": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] },
    "Error Response": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
