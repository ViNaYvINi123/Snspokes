{
  "name": "SNSpokes — Self-Healing + Alert System",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 5 }] } },
      "id": "schedule",
      "name": "Every 5 Min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) as error_count, MAX(created_at) as last_error FROM sn_error_logs WHERE level IN ('error','critical') AND created_at > NOW() - INTERVAL '5 minutes'",
        "additionalFields": {}
      },
      "id": "check-errors",
      "name": "Count Recent Errors",
      "type": "n8n-nodes-base.postgres",
      "credentials": { "postgres": { "id": "1", "name": "Postgres snspokes" } },
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst count = parseInt(data.error_count || 0);\nconst threshold = 10;\nreturn [{ json: { error_count: count, threshold, spike: count >= threshold, severity: count >= 20 ? 'critical' : count >= 10 ? 'high' : 'normal' } }];"
      },
      "id": "evaluate",
      "name": "Evaluate Threshold",
      "type": "n8n-nodes-base.code",
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.spike }}", "value2": true }] }
      },
      "id": "is-spike",
      "name": "Error Spike?",
      "type": "n8n-nodes-base.if",
      "position": [900, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT message, source, COUNT(*) as count FROM sn_error_logs WHERE created_at > NOW() - INTERVAL '5 minutes' GROUP BY message, source ORDER BY count DESC LIMIT 5",
        "additionalFields": {}
      },
      "id": "get-top-errors",
      "name": "Get Top Errors",
      "type": "n8n-nodes-base.postgres",
      "credentials": { "postgres": { "id": "1", "name": "Postgres snspokes" } },
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "const topErrors = $input.all().map(e => e.json);\nconst evalData = $('Evaluate Threshold').first().json;\nconst summary = topErrors.map(e => `• [${e.count}x] ${e.source}: ${e.message.substring(0,80)}`).join('\\n');\nreturn [{ json: { alert_message: `🚨 *Error Spike Detected!*\\n${evalData.error_count} errors in last 5 minutes (threshold: ${evalData.threshold})\\n\\n*Top Errors:*\\n${summary}`, severity: evalData.severity, error_count: evalData.error_count } }];"
      },
      "id": "build-alert",
      "name": "Build Alert",
      "type": "n8n-nodes-base.code",
      "position": [1340, 200]
    },
    {
      "parameters": {
        "url": "={{ $env.SLACK_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [{ "name": "text", "value": "={{ $json.alert_message }}" }]
        },
        "options": { "timeout": 10000, "response": { "response": { "neverError": true } } }
      },
      "id": "slack-alert",
      "name": "Send Slack Alert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 200]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE sn_feature_flags SET enabled=false WHERE key='beta_features' AND enabled=true AND (SELECT COUNT(*) FROM sn_error_logs WHERE level='critical' AND created_at > NOW() - INTERVAL '5 minutes') > 20 RETURNING key",
        "additionalFields": {}
      },
      "id": "self-heal",
      "name": "Disable Beta on Critical",
      "type": "n8n-nodes-base.postgres",
      "credentials": { "postgres": { "id": "1", "name": "Postgres snspokes" } },
      "position": [1560, 360]
    }
  ],
  "connections": {
    "Every 5 Min": { "main": [[{ "node": "Count Recent Errors", "type": "main", "index": 0 }]] },
    "Count Recent Errors": { "main": [[{ "node": "Evaluate Threshold", "type": "main", "index": 0 }]] },
    "Evaluate Threshold": { "main": [[{ "node": "Error Spike?", "type": "main", "index": 0 }]] },
    "Error Spike?": { "main": [[{ "node": "Get Top Errors", "type": "main", "index": 0 }], []] },
    "Get Top Errors": { "main": [[{ "node": "Build Alert", "type": "main", "index": 0 }]] },
    "Build Alert": { "main": [[{ "node": "Send Slack Alert", "type": "main", "index": 0 }, { "node": "Disable Beta on Critical", "type": "main", "index": 0 }]] }
  },
  "active": true
}
