{
  "name": "SNSpokes — AI Chatbot (OpenRouter)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sn-chatbot",
        "responseMode": "responseNode"
      },
      "id": "webhook",
      "name": "Chatbot Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst question = (body.question || '').trim();\nconst history = body.history || [];\nif (!question || question.length < 2) return [{ json: { valid: false, error: 'Question required' } }];\n\nconst messages = [\n  { role: 'system', content: 'You are an expert ServiceNow Integration Hub assistant for snspokes. You ONLY answer ServiceNow-related questions. Be concise, practical, and developer-friendly. Include code snippets when helpful.' },\n  ...history.slice(-6),\n  { role: 'user', content: question }\n];\n\nreturn [{ json: { valid: true, question, messages } }];"
      },
      "id": "validate",
      "name": "Validate & Build Messages",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.valid }}", "value2": true }] }
      },
      "id": "check-valid",
      "name": "Valid?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "HTTP-Referer", "value": "https://snspokes.com" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "meta-llama/llama-3.1-8b-instruct:free" },
            { "name": "max_tokens", "value": 1000 },
            { "name": "messages", "value": "={{ $json.messages }}" }
          ]
        },
        "options": { "timeout": 60000, "response": { "response": { "neverError": true } } }
      },
      "id": "openrouter",
      "name": "OpenRouter — Chat",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 200]
    },
    {
      "parameters": {
        "jsCode": "const res = $input.first().json;\nconst answer = res?.choices?.[0]?.message?.content || '⚠️ AI temporarily unavailable. Please try again.';\nreturn [{ json: { success: true, answer, model: res.model } }];"
      },
      "id": "parse",
      "name": "Parse",
      "type": "n8n-nodes-base.code",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: false, answer: '⚠️ Invalid request: ' + ($json.error || 'Question required') } }];"
      },
      "id": "error-resp",
      "name": "Error",
      "type": "n8n-nodes-base.code",
      "position": [900, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseHeaders": { "entries": [{ "name": "Content-Type", "value": "application/json" },{ "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "respond",
      "name": "Send Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1340, 300]
    }
  ],
  "connections": {
    "Chatbot Webhook": { "main": [[{ "node": "Validate & Build Messages", "type": "main", "index": 0 }]] },
    "Validate & Build Messages": { "main": [[{ "node": "Valid?", "type": "main", "index": 0 }]] },
    "Valid?": { "main": [[{ "node": "OpenRouter — Chat", "type": "main", "index": 0 }],[{ "node": "Error", "type": "main", "index": 0 }]] },
    "OpenRouter — Chat": { "main": [[{ "node": "Parse", "type": "main", "index": 0 }]] },
    "Parse": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] },
    "Error": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] }
  },
  "active": true
}
